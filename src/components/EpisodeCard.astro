---
import type { Episode } from '../lib/episodes';

export interface Props {
  episode: Episode;
}
const { episode } = Astro.props as Props;
---
<article
  class="ep-card"
  data-title={episode.title.toLowerCase()}
  data-tags={episode.categories.join('|').toLowerCase()}
  data-keywords={episode.tags.join('|').toLowerCase()}
  data-guest={(episode.guest || '').toLowerCase()}
>
  <a href={episode.url} class="ep-card-art" aria-hidden="true" tabindex="-1">
    {episode.imageUrl && (
      <img src={episode.imageUrl} alt="" loading="lazy" width="600" height="600" />
    )}
  </a>

  <div class="ep-card-body">
    <div class="ep-card-meta">
      {episode.number && <span>Ep. {episode.number}</span>}
      <span>{episode.pubDateDisplay}</span>
      {episode.durationDisplay && <span>{episode.durationDisplay}</span>}
    </div>

    <h3 class="ep-card-title">
      <a href={episode.url}>{episode.title}</a>
    </h3>

    {episode.guest && (
      <p class="ep-card-guest">with {episode.guest}</p>
    )}

    <p class="ep-card-excerpt">{episode.excerpt}</p>

    {episode.categories.length > 0 && (
      <div class="ep-card-tags">
        {episode.categories.slice(0, 3).map((c) => (
          <span class="tag">{c}</span>
        ))}
      </div>
    )}

    <div class="ep-card-actions">
      <a href={episode.url} class="btn btn-primary">Listen Now</a>
      <a href={episode.url} class="btn btn-ghost">View Episode</a>
    </div>
  </div>
</article>

<style>
  .ep-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: border-color .2s var(--ease), transform .2s var(--ease);
  }
  .ep-card:hover { border-color: var(--ink); transform: translateY(-2px); }

  @media (max-width: 720px) {
    .ep-card { grid-template-columns: 1fr; padding: 1.25rem; }
  }

  .ep-card-art {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-alt);
    aspect-ratio: 1 / 1;
  }
  .ep-card-art img { width: 100%; height: 100%; object-fit: cover; }

  @media (max-width: 720px) {
    .ep-card-art { max-width: 240px; }
  }

  .ep-card-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .ep-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-mute);
    font-weight: 600;
    margin-bottom: .6rem;
  }

  .ep-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.1vw, 1.55rem);
    margin: 0 0 .4rem;
    line-height: 1.2;
  }
  .ep-card-title a { color: var(--ink); text-decoration: none; }
  .ep-card-title a:hover { color: var(--clay); }

  .ep-card-guest {
    font-style: italic;
    color: var(--ink-soft);
    margin-bottom: .6rem;
    font-size: .95rem;
  }

  .ep-card-excerpt {
    color: var(--ink-soft);
    font-size: .98rem;
    margin-bottom: 1rem;
    /* clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ep-card-tags { margin-bottom: 1rem; }

  .ep-card-actions {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
  }
</style>
